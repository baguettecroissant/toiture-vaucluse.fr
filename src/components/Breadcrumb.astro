---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---
<div class="container">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      {items.map((item, index) => (
        <li>
          {index > 0 && <span class="separator">/</span>}
          {item.href ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span class="active-page" aria-current="page">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
</div>

<style>
  .breadcrumb {
    padding: 15px 0;
    font-size: 13.5px;
    font-family: var(--font-body);
  }
  .breadcrumb ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 0;
  }
  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
  }
  .breadcrumb a {
    color: var(--accent);
    font-weight: 600;
    transition: var(--transition);
  }
  .breadcrumb a:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
  .active-page {
    color: var(--text-muted);
    font-weight: 500;
  }
  .separator {
    color: var(--border-color);
    font-size: 11px;
  }
</style>
