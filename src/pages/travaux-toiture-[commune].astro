---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';

export async function getStaticPaths() {
  return communes.map((c) => ({
    params: { commune: c.slug },
    props: { commune: c },
  }));
}

const { commune } = Astro.props;
const pageType = 'refection';
const local = generateCommuneContent(commune, pageType);
const prices = getDynamicPrices(commune);
const nearby = getSmartNearbyCommunes(commune.slug, communes, 5, 2);

const title = local.title;
const description = commune.introText;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes Vaucluse (84)", href: "/communes/" },
  { label: `Rénovation Toiture à ${commune.nom}` }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={local.faqItems}
    breadcrumbItems={[
      { label: "Accueil", href: "/" },
      { label: "Villes Vaucluse", href: "/communes/" },
      { label: `Rénovation Toiture à ${commune.nom}` }
    ]}
    communeName={commune.nom}
    communeData={commune}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Localized Hero Section -->
  <section style="background: linear-gradient(135deg, rgba(112,26,117,0.06) 0%, rgba(180,83,9,0.03) 100%); padding: 50px 0; border-bottom: 2px solid var(--border-color); font-family: var(--font-body);">
    <div class="container">
      <div class="two-column-layout">
        <!-- Hero Text -->
        <div style="display: flex; flex-direction: column; justify-content: center;">
          <div class="badge-pill" style="width: max-content; margin-bottom: 20px;">
            🛡️ Couverture &amp; Rénovation — Expertise {commune.nom}
          </div>
          <h1 style="font-family: var(--font-heading); font-size: 38px; font-weight: 800; color: var(--primary); line-height: 1.2; margin-bottom: 20px;">
            Rénovation de Toiture à <span style="color: var(--secondary);">{commune.nom}</span> ({commune.codePostal})
          </h1>
          <p style="font-size: 16.5px; line-height: 1.6; color: var(--text); margin-bottom: 25px;">
            {commune.introText}
          </p>
          
          <div style="background: white; border: 1.5px solid var(--border-color); border-left: 4px solid var(--primary); padding: 18px; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); margin-bottom: 25px;">
            <div style="font-weight: 750; color: var(--primary); margin-bottom: 5px; font-size: 14.5px;">💡 Note des Couvreurs du 84 :</div>
            <p style="font-size: 13.5px; color: var(--text-muted); margin: 0; line-height: 1.5;">
              Face aux intempéries comme le vent fort du Mistral ou les fortes chaleurs provençales, l'ancrage mécanique des tuiles et la pose d'un écran sous-toiture HPV sont indispensables pour garantir l'étanchéité et le confort thermique de votre toit.
            </p>
          </div>
        </div>

        <!-- Hero Form -->
        <div>
          <StepsForm initialZip={commune.codePostal} initialCommune={commune.nom} />
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Analysis Section -->
  <section style="padding: 70px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Spécificités techniques &amp; Rénovation de Toit à {commune.nom}
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Les critères essentiels pour réussir vos travaux de toiture dans le Vaucluse.
        </p>
      </div>

      <div class="grid-3">
        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">⛈️</div>
          <h3 style="font-family: var(--font-heading); font-size: 18.5px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Résistance Climat &amp; Vent</h3>
          <p style="font-size: 14.0px; color: var(--text-muted); line-height: 1.6; margin: 0;" set:html={local.climateContext}></p>
        </div>

        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🏛️</div>
          <h3 style="font-family: var(--font-heading); font-size: 18.5px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Urbanisme &amp; Règles ABF</h3>
          <p style="font-size: 14.0px; color: var(--text-muted); line-height: 1.6; margin: 0;" set:html={local.abfRegulations}></p>
        </div>

        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🏡</div>
          <h3 style="font-family: var(--font-heading); font-size: 18.5px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Architecture Locale</h3>
          <p style="font-size: 14.0px; color: var(--text-muted); line-height: 1.6; margin: 0;" set:html={local.housingTypologyInsight}></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Energy & Valuation Section -->
  <section style="padding: 70px 0; background-color: #FFFDF8; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 900px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Pourquoi faire isoler et rénover votre toit à {commune.nom} ?
        </h2>
      </div>

      <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm); margin-bottom: 25px;">
        <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 25px;">
          <span style="font-size: 32px;">🔥</span>
          <div>
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Économies d'énergie &amp; Fraîcheur d'été</h3>
            <p style="font-size: 14.5px; color: var(--text-muted); line-height: 1.6; margin: 0;" set:html={local.energyProfileText}></p>
          </div>
        </div>
        <hr style="border: 0; border-top: 1px solid var(--border-color); margin-bottom: 25px;" />
        <div style="display: flex; align-items: flex-start; gap: 15px;">
          <span style="font-size: 32px;">📈</span>
          <div>
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Valorisation Immobilière de votre Mas ou Villa</h3>
            <p style="font-size: 14.5px; color: var(--text-muted); line-height: 1.6; margin: 0;" set:html={local.realEstateInsight}></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fiche Technique Communale & Liens Officiels -->
  <section style="padding: 70px 0; background-color: white; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color); font-family: var(--font-body);">
    <div class="container" style="max-width: 900px;">
      <h2 style="font-family: var(--font-heading); font-size: 28px; font-weight: 800; color: var(--primary); text-align: center; margin-bottom: 30px;">
        📋 Fiche Technique de Couverture &amp; Données Locales — {commune.nom}
      </h2>
      
      <div class="grid-2" style="gap: 30px; margin-bottom: 40px;">
        <!-- Left: Données Géographiques & Administratives -->
        <div style="background: var(--card-bg); border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-md);">
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 1.5px solid var(--border-color); padding-bottom: 8px;">
            📍 Informations Territoriales
          </h3>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; font-size: 14.0px;">
            <li style="border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 5px;"><strong>Département :</strong> Vaucluse (84)</li>
            <li style="border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 5px;"><strong>Zone Géographique :</strong> {commune.microRegionLabel}</li>
            <li style="border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 5px;"><strong>Intercommunalité :</strong> {commune.intercommunalite}</li>
            <li style="border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 5px;"><strong>Altitude moyenne :</strong> {commune.altitude} mètres (exigence de tuiles certifiées antigel)</li>
            <li style="border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 5px;"><strong>Population Municipale :</strong> {commune.population.toLocaleString('fr-FR')} habitants</li>
            <li><strong>Monuments de référence :</strong> Proche de {commune.landmarks.join(' et de ')}</li>
          </ul>
        </div>
        
        <!-- Right: Conseils Professionnels & Réglementation -->
        <div style="background: var(--card-bg); border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-md);">
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 1.5px solid var(--border-color); padding-bottom: 8px;">
            💡 Conseils de l'Artisan Local
          </h3>
          <p style="font-size: 13.5px; line-height: 1.6; color: var(--text-muted); margin-bottom: 15px;">
            {commune.conseilLocal}
          </p>
          <div style="background: #FFF7ED; border: 1px solid #FED7AA; padding: 12px; border-radius: var(--radius-sm); font-size: 12.5px; color: #9A3412;">
            <strong>Recommandation :</strong> Pour un projet visible depuis {commune.landmarks[0]}, assurez-vous de consulter le PLU en mairie de <strong>{commune.nom}</strong> avant tout démarrage de chantier.
          </div>
        </div>
      </div>
      
      <!-- Liens Utiles Externes Certifiés -->
      <div style="background: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 30px;">
        <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 15px; text-align: center;">
          🔗 Ressources Administratives &amp; Aides Officielles pour {commune.nom}
        </h3>
        <p style="font-size: 13.5px; text-align: center; color: var(--text-muted); margin-bottom: 20px;">
          Consultez les sites gouvernementaux pour sécuriser vos démarches administratives et financières de rénovation thermique :
        </p>
        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 15px;">
          <a href="https://www.service-public.fr/particuliers/vosdroits/F17578" target="_blank" rel="noopener nofollow" style="background: white; border: 1.5px solid var(--border-color); padding: 10px 18px; border-radius: 30px; font-size: 13px; font-weight: bold; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 6px;">
            📄 Déclaration Préalable de Travaux &rarr;
          </a>
          <a href="https://france-renov.gouv.fr/" target="_blank" rel="noopener nofollow" style="background: white; border: 1.5px solid var(--border-color); padding: 10px 18px; border-radius: 30px; font-size: 13px; font-weight: bold; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 6px;">
            ☀️ Aides Énergie France Rénov' &rarr;
          </a>
          <a href="https://www.anah.gouv.fr/" target="_blank" rel="noopener nofollow" style="background: white; border: 1.5px solid var(--border-color); padding: 10px 18px; border-radius: 30px; font-size: 13px; font-weight: bold; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 6px;">
            🏢 Subventions Anah &rarr;
          </a>
          <a href="http://www.vaucluse.gouv.fr/" target="_blank" rel="noopener nofollow" style="background: white; border: 1.5px solid var(--border-color); padding: 10px 18px; border-radius: 30px; font-size: 13px; font-weight: bold; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 6px;">
            🏛️ Services de l'État dans le Vaucluse &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Prices Section -->
  <section style="padding: 70px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Tarifs Moyen des Couvreurs à {commune.nom} (84)
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Indicateurs de prix moyens constatés dans le Vaucluse en 2026.
        </p>
      </div>

      <div style="max-width: 850px; margin: 0 auto; overflow-x: auto; background: white; border: 2px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14.5px;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Type de Travaux</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Fourchette de Prix 2026</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Facturation</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles romanes (terre cuite)</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.refectionRomane.min} – {prices.refectionRomane.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au m² (pose comprise)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles canal traditionnelles</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.refectionCanal.min} – {prices.refectionCanal.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au m² (pose comprise)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Démoussage toiture + Hydrofuge imperméable</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.demoussageHydro.min} – {prices.demoussageHydro.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au m² (traitement perlant)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Réparation de fuite d'urgence (Mistral/tempête)</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.reparationFuite.min} – {prices.reparationFuite.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">par diagnostic/intervention</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Remplacement gouttière Zinc ou Alu</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.zinguerieMl.min} – {prices.zinguerieMl.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au mètre linéaire</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Rénovation faîtage (closoir ventilé)</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.faitageMl.min} – {prices.faitageMl.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au mètre linéaire</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Isolation thermique sarking (laine de bois/roche)</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.isolationSarking.min} – {prices.isolationSarking.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au m² (éligible aides RGE)</td>
            </tr>
            <tr style="background: var(--primary-light);">
              <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Traitement charpente bois (xylophages)</td>
              <td style="padding: 16px 20px;"><span class="price-tag">{prices.charpenteM2.min} – {prices.charpenteM2.max} €</span></td>
              <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <div style="text-align: center; margin-top: 35px;">
        <a href="#devis" class="btn-primary" style="display: inline-block;">📋 Recevoir une simulation personnalisée &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section style="padding: 70px 0; background-color: var(--bg); border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 850px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">
          Foire aux Questions Toiture à {commune.nom}
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Questions fréquentes sur les toits dans le Vaucluse.
        </p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 20px;">
        {local.faqItems.map((item) => (
          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 25px; box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 17.5px; font-weight: 700; color: var(--primary); margin-bottom: 10px; display: flex; align-items: center; gap: 10px;">
              <span style="color: var(--secondary);">Q.</span> {item.q}
            </h3>
            <p style="font-size: 14.5px; color: var(--text-muted); line-height: 1.6; margin: 0; padding-left: 25px;">
              {item.a}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-Linking: Autres services pour cette commune -->
  <section style="padding: 50px 0; background-color: #FFFDF8; border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 900px;">
      <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--primary); text-align: center; margin-bottom: 10px;">
        Nos autres services toiture à {commune.nom}
      </h3>
      <p style="text-align: center; font-size: 14px; color: var(--text-muted); margin-bottom: 30px;">
        Découvrez aussi nos prestations complémentaires pour votre toiture à {commune.nom} ({commune.codePostal}).
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
        <a href={`/restauration-toiture-${commune.slug}/`} style="display: block; background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; text-decoration: none; transition: var(--transition); box-shadow: var(--shadow-sm);">
          <span style="font-size: 22px;">🧼</span>
          <h4 style="font-family: var(--font-heading); font-size: 15px; font-weight: 700; color: var(--primary); margin: 8px 0 5px;">Nettoyage &amp; Démoussage à {commune.nom}</h4>
          <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Nettoyage basse pression, traitement fongicide et hydrofuge pour prolonger l'éclat et l'étanchéité de vos tuiles.</p>
        </a>
        <a href={`/artisan-qualifie-${commune.slug}/`} style="display: block; background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; text-decoration: none; transition: var(--transition); box-shadow: var(--shadow-sm);">
          <span style="font-size: 22px;">👤</span>
          <h4 style="font-family: var(--font-heading); font-size: 15px; font-weight: 700; color: var(--primary); margin: 8px 0 5px;">Couvreur RGE à {commune.nom}</h4>
          <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Trouvez un artisan couvreur certifié RGE à {commune.nom} pour vos travaux énergétiques et les aides de l'ANAH.</p>
        </a>
        <a href="/tarifs/" style="display: block; background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; text-decoration: none; transition: var(--transition); box-shadow: var(--shadow-sm);">
          <span style="font-size: 22px;">🧮</span>
          <h4 style="font-family: var(--font-heading); font-size: 15px; font-weight: 700; color: var(--primary); margin: 8px 0 5px;">Grille de Tarifs Toiture 2026</h4>
          <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Consultez nos grilles de prix détaillées par type de couverture, surface et prestation dans le Vaucluse.</p>
        </a>
      </div>
      <div style="margin-top: 25px; text-align: center; display: flex; flex-wrap: wrap; justify-content: center; gap: 12px;">
        <a href="/guides/prix-toiture-vaucluse-2026/" style="font-size: 13px; color: var(--accent); font-weight: 600;">📊 Budget complet Vaucluse 2026</a>
        <a href="/guide-mistral-toiture/" style="font-size: 13px; color: var(--accent); font-weight: 600;">💨 Guide de survie Mistral</a>
        <a href="/restauration-mas-provencal/" style="font-size: 13px; color: var(--accent); font-weight: 600;">🏡 Restauration Mas Provençal</a>
        <a href="/guides/genoises-provencales/" style="font-size: 13px; color: var(--accent); font-weight: 600;">🏛️ Guide Génoises Tradition</a>
      </div>
    </div>
  </section>

  <!-- Nearby Link Section -->
  <section style="padding: 60px 0; background-color: var(--card-bg); border-top: 1.5px solid var(--border-color);">
    <div class="container">
