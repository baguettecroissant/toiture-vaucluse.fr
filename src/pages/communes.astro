---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import communes from '../data/communes.json';

const title = "Couvreurs RGE & Artisans Toiture dans le Vaucluse (84) | Annuaire par Ville";
const description = "Retrouvez nos guides de couverture, démoussage hydrofuge et estimation de devis pour les principales communes du Vaucluse. Devis gratuits.";

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes du Vaucluse (84)" }
];

// Group communes by intercommunalité
const groups: Record<string, typeof communes> = {};
communes.forEach(c => {
  const interco = c.intercommunalite || "Autres Communes du Vaucluse";
  if (!groups[interco]) {
    groups[interco] = [];
  }
  groups[interco].push(c);
});

// Sort interco groups by number of communes descending, putting "Autres Communes" last
const sortedGroups = Object.entries(groups).sort((a, b) => {
  if (a[0].startsWith("Autres")) return 1;
  if (b[0].startsWith("Autres")) return -1;
  return b[1].length - a[1].length;
});
---

<Layout title={title} description={description}>
  <Breadcrumb items={breadcrumbItems} />

  <section style="padding: 50px 0 80px; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h1 style="font-family: var(--font-heading); font-size: 36px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Annuaire des Travaux de Toiture par Commune (84)
        </h1>
        <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6;">
          Sélectionnez votre ville ci-dessous pour accéder aux tarifs locaux, aux aides de votre communauté d'agglomération et pour estimer le budget de votre projet de toiture ou démoussage.
        </p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 45px;">
        {sortedGroups.map(([groupName, list]) => (
          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
            <h2 style="font-family: var(--font-heading); font-size: 20px; font-weight: 800; color: var(--primary); border-bottom: 2px solid var(--border-color); padding-bottom: 10px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
              🏛️ {groupName} <span style="background: var(--primary-light); color: var(--primary); font-size: 12px; padding: 3px 8px; border-radius: 20px; font-weight: bold;">{list.length} communes</span>
            </h2>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
              {list.map((c) => (
                <div style="background: var(--bg); border: 1px solid var(--border-color); padding: 15px; border-radius: var(--radius-sm); transition: var(--transition);">
                  <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 10px;">
                    {c.nom} ({c.codePostal})
                  </h3>
                  <div style="display: flex; flex-direction: column; gap: 5px; font-size: 12.5px;">
                    <a href={`/travaux-toiture-${c.slug}/`} style="color: var(--primary); font-weight: 700; display: flex; align-items: center; gap: 5px;">
                      🔨 Rénovation &amp; Couverture &rarr;
                    </a>
                    <a href={`/restauration-toiture-${c.slug}/`} style="color: var(--primary); font-weight: 700; display: flex; align-items: center; gap: 5px;">
                      🧼 Nettoyage &amp; Restauration &rarr;
                    </a>
                    <a href={`/artisan-qualifie-${c.slug}/`} style="color: var(--primary); font-weight: 700; display: flex; align-items: center; gap: 5px;">
                      👤 Couvreur Certifié RGE &rarr;
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
