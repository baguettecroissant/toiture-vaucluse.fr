---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import config from '../../data/config.json';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('guides');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} | ${config.brandName}`;
const description = post.data.description;
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={[
      { label: "Accueil", href: "/" },
      { label: "Guides", href: "/guides/" },
      { label: post.data.title }
    ]}
  />

  <Breadcrumb items={[
    { label: "Accueil", href: "/" },
    { label: "Guides", href: "/guides/" },
    { label: post.data.title }
  ]} />

  <section style="padding: 50px 0 80px; background-color: var(--card-bg);">
    <div class="container">
      <div class="two-column-layout" style="align-items: start;">
        
        <!-- Main Content -->
        <div>
          <article style="display: flex; flex-direction: column; gap: 20px;">
            <div style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px;">
              <span style="font-family: var(--font-mono); font-size: 13.5px; color: var(--accent); font-weight: 700;">
                📅 Publié le {new Date(post.data.publishDate).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })} par {post.data.author || 'Le Maître Couvreur'}
              </span>
              <h1 style="margin: 0; font-size: 2.2rem; color: var(--primary); line-height: 1.25; font-family: var(--font-heading); font-weight: 800;">
                {post.data.title}
              </h1>
            </div>

            {post.data.image && (
              <div style="border-radius: var(--radius-md); overflow: hidden; max-height: 380px; width: 100%; border: 2px solid var(--border-color); box-shadow: var(--shadow-sm); margin-bottom: 20px;">
                <img 
                  src={post.data.image} 
                  alt={post.data.title} 
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
            )}

            <div class="article-markdown-body" style="font-size: 16.5px; line-height: 1.7; color: var(--text); display: flex; flex-direction: column; gap: 15px; font-family: var(--font-body);">
              <Content />
            </div>
          </article>
        </div>

        <!-- Sidebar -->
        <aside style="display: flex; flex-direction: column; gap: 30px;">
          <div style="background: linear-gradient(135deg, var(--primary) 0%, #1e1b4b 100%); color: white; padding: 30px; border-radius: var(--radius-md); box-shadow: var(--shadow-md);">
            <h3 style="color: white; font-family: var(--font-heading); font-size: 20px; font-weight: 700; margin-bottom: 12px;">Besoin d'un couvreur dans le 84 ?</h3>
            <p style="font-size: 14px; line-height: 1.5; margin-bottom: 20px; color: var(--primary-light);">
              Faites estimer vos travaux de couverture, démoussage ou isolation. Recevez gratuitement 3 devis comparatifs d'artisans couvreurs qualifiés RGE du Vaucluse.
            </p>
            <a href="/devis/" class="contact-btn" style="display: block; text-align: center; background: var(--secondary); color: var(--primary) !important;">Obtenir 3 Devis RGE</a>
          </div>

          <div style="background: white; border: 1.5px solid var(--border-color); border-left: 4px solid var(--secondary); border-radius: var(--radius-sm); padding: 25px; box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 15px;">Dossiers Rénovation Vaucluse</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px; font-size: 14px; padding: 0;">
              <li><a href="/tarifs/" style="color: var(--text); font-weight: bold;">📊 Grille de Tarifs 2026</a></li>
              <li><a href="/guide-mistral-toiture/" style="color: var(--text); font-weight: bold;">💨 Risques Tempêtes Mistral</a></li>
              <li><a href="/restauration-mas-provencal/" style="color: var(--text); font-weight: bold;">🏡 Restauration Mas Provençal</a></li>
              <li><a href="/communes/" style="color: var(--text); font-weight: bold;">🗺️ Toutes les Villes (84)</a></li>
            </ul>
          </div>

          <div style="background: white; border: 1.5px solid var(--border-color); border-left: 4px solid var(--accent); border-radius: var(--radius-sm); padding: 25px; box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 15px;">🏠 Villes les plus demandées</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 10px; font-size: 13.5px; padding: 0;">
              <li><a href="/travaux-toiture-avignon/" style="color: var(--accent); font-weight: 700;">Couvreur à Avignon (84000)</a></li>
              <li><a href="/travaux-toiture-carpentras/" style="color: var(--accent); font-weight: 700;">Couvreur à Carpentras (84200)</a></li>
              <li><a href="/travaux-toiture-orange/" style="color: var(--accent); font-weight: 700;">Couvreur à Orange (84100)</a></li>
              <li><a href="/travaux-toiture-cavaillon/" style="color: var(--accent); font-weight: 700;">Couvreur à Cavaillon (84300)</a></li>
              <li><a href="/travaux-toiture-l-isle-sur-la-sorgue/" style="color: var(--accent); font-weight: 700;">Couvreur à L'Isle-sur-la-Sorgue</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Custom prose overrides for Markdown content styling inside guides */
  .article-markdown-body h2 {
    font-size: 1.6rem;
    color: var(--primary);
    margin-top: 35px;
    margin-bottom: 15px;
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 5px;
    font-family: var(--font-heading);
    font-weight: 800;
  }
  .article-markdown-body h3 {
    font-size: 1.3rem;
    color: var(--accent);
    margin-top: 25px;
    margin-bottom: 10px;
    font-family: var(--font-heading);
    font-weight: 750;
  }
  .article-markdown-body p {
    margin-bottom: 15px;
  }
  .article-markdown-body ul, .article-markdown-body ol {
    margin-left: 25px;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .article-markdown-body li strong {
    color: var(--primary);
  }
  .article-markdown-body blockquote {
    border-left: 4px solid var(--secondary);
    background-color: var(--primary-light);
    padding: 15px 20px;
    margin: 20px 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-style: italic;
  }
  .article-markdown-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 25px 0;
    box-shadow: var(--shadow-sm);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 2px solid var(--border-color);
  }
  .article-markdown-body th {
    background-color: var(--primary);
    color: white;
    font-weight: 700;
    padding: 12px 15px;
    text-align: left;
    font-family: var(--font-heading);
  }
  .article-markdown-body td {
    padding: 12px 15px;
    border-bottom: 1px solid var(--border-color);
    background-color: var(--card-bg);
  }
  .article-markdown-body tr:last-child td {
    border-bottom: none;
  }
  .article-markdown-body table th, .article-markdown-body table td {
    font-size: 14.5px;
  }
  aside a {
    text-decoration: none;
    transition: var(--transition);
  }
  aside a:hover {
    color: var(--accent) !important;
  }
</style>
