---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import config from '../../data/config.json';
import { getCollection } from 'astro:content';

const posts = await getCollection('guides');
const sortedPosts = posts.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const title = `Guides, Conseils & Tarifs Toiture dans le Vaucluse (84) | Devis RGE`;
const description = `Découvrez tous nos guides techniques et pratiques pour la réfection de toiture, le traitement hydrofuge perlant, les aides énergie 2026 et les spécificités du 84.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Guides Toiture" }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={[
      { label: "Accueil", href: "/" },
      { label: "Guides Toiture" }
    ]}
  />

  <Breadcrumb items={breadcrumbItems} />

  <section style="padding: 50px 0 80px; background-color: var(--card-bg);">
    <div class="container">
      <div class="two-column-layout" style="align-items: start;">
        
        <!-- Main Content -->
        <div>
          <h1 style="font-family: var(--font-heading); font-size: 36px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
            Guides &amp; Conseils Techniques Toiture dans le Vaucluse
          </h1>
          <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6; margin-bottom: 40px;">
            Retrouvez les dossiers conseils de nos experts couvreurs du 84 pour réussir vos projets de couverture et de charpente. Réglementations locales ABF à Avignon, Orange et dans le Luberon, aides nationales et locales pour l'isolation de toit, méthodes de démoussage et sécurité face aux tempêtes de mistral.
          </p>

          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px;">
            <!-- Dedicated static guides first (manually added for visibility) -->
            <article class="card" style="display: flex; flex-direction: column; height: 100%; overflow: hidden; background-color: var(--card-bg); transition: var(--transition);">
              <div style="width: 100%; height: 160px; overflow: hidden; background-color: var(--primary-light); border-bottom: 1.5px solid var(--border-color);">
                <img 
                  src="/images/guides/guide-2.png" 
                  alt="Mistral et toiture dans le Vaucluse" 
                  style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition);"
                  loading="lazy"
                />
              </div>
              <div style="padding: 20px; flex-grow: 1; display: flex; flex-direction: column; gap: 10px; font-family: var(--font-body);">
                <span style="font-family: var(--font-mono); font-size: 12px; color: var(--accent); font-weight: 700;">
                  📅 Dossier Spécial
                </span>
                <h3 style="font-size: 1.2rem; margin: 0; line-height: 1.35; color: var(--primary); font-family: var(--font-heading); font-weight: 700;">
                  <a href="/guide-mistral-toiture/" style="text-decoration: none; color: inherit;">
                    Mistral et toiture : sécuriser vos tuiles contre les rafales dans le Vaucluse
                  </a>
                </h3>
                <p style="font-size: 14px; color: var(--text-muted); line-height: 1.5; margin: 0; flex-grow: 1;">
                  Nos solutions techniques indispensables pour clouer, crocheter et sceller vos toits provençaux face aux tempêtes.
                </p>
                <a href="/guide-mistral-toiture/" style="display: inline-block; align-self: flex-start; margin-top: 10px; font-weight: 700; color: var(--accent); text-decoration: none;">
                  Lire le dossier &rarr;
                </a>
              </div>
            </article>

            <article class="card" style="display: flex; flex-direction: column; height: 100%; overflow: hidden; background-color: var(--card-bg); transition: var(--transition);">
              <div style="width: 100%; height: 160px; overflow: hidden; background-color: var(--primary-light); border-bottom: 1.5px solid var(--border-color);">
                <img 
                  src="/images/guides/guide-7.png" 
                  alt="Restauration mas provençal" 
                  style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition);"
                  loading="lazy"
                />
              </div>
              <div style="padding: 20px; flex-grow: 1; display: flex; flex-direction: column; gap: 10px; font-family: var(--font-body);">
                <span style="font-family: var(--font-mono); font-size: 12px; color: var(--accent); font-weight: 700;">
                  📅 Dossier Patrimoine
                </span>
                <h3 style="font-size: 1.2rem; margin: 0; line-height: 1.35; color: var(--primary); font-family: var(--font-heading); font-weight: 700;">
                  <a href="/restauration-mas-provencal/" style="text-decoration: none; color: inherit;">
                    Restauration de mas provençal : isolation sous toiture &amp; confort thermique
                  </a>
                </h3>
                <p style="font-size: 14px; color: var(--text-muted); line-height: 1.5; margin: 0; flex-grow: 1;">
                  Comment concilier isolation thermique moderne (laine de bois, sarking) et respect de l'architecture historique en pierre.
                </p>
                <a href="/restauration-mas-provencal/" style="display: inline-block; align-self: flex-start; margin-top: 10px; font-weight: 700; color: var(--accent); text-decoration: none;">
                  Lire le dossier &rarr;
                </a>
              </div>
            </article>

            <!-- Dynamic Markdown Collection Guides -->
            {sortedPosts.map((post) => (
              <article class="card" style="display: flex; flex-direction: column; height: 100%; overflow: hidden; background-color: var(--card-bg); transition: var(--transition);">
                {post.data.image && (
                  <div style="width: 100%; height: 160px; overflow: hidden; background-color: var(--primary-light); border-bottom: 1.5px solid var(--border-color);">
                    <img 
                      src={post.data.image} 
                      alt={post.data.title} 
                      style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition);"
                      loading="lazy"
                    />
                  </div>
                )}
                <div style="padding: 20px; flex-grow: 1; display: flex; flex-direction: column; gap: 10px; font-family: var(--font-body);">
                  <span style="font-family: var(--font-mono); font-size: 12px; color: var(--accent); font-weight: 700;">
                    📅 {new Date(post.data.publishDate).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </span>
                  <h3 style="font-size: 1.2rem; margin: 0; line-height: 1.35; color: var(--primary); font-family: var(--font-heading); font-weight: 700;">
                    <a href={`/guides/${post.id}/`} style="text-decoration: none; color: inherit;">
                      {post.data.title}
                    </a>
                  </h3>
                  <p style="font-size: 14px; color: var(--text-muted); line-height: 1.5; margin: 0; flex-grow: 1;">
                    {post.data.description}
                  </p>
                  <a 
                    href={`/guides/${post.id}/`} 
                    style="display: inline-block; align-self: flex-start; margin-top: 10px; font-weight: 700; color: var(--accent); text-decoration: none;"
                  >
                    Lire l'article &rarr;
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside style="display: flex; flex-direction: column; gap: 30px;">
          <div style="background: linear-gradient(135deg, var(--primary) 0%, #1e1b4b 100%); color: white; padding: 30px; border-radius: var(--radius-md); box-shadow: var(--shadow-md);">
            <h3 style="color: white; font-family: var(--font-heading); font-size: 20px; font-weight: 700; margin-bottom: 12px;">Devis Couverture Gratuit</h3>
            <p style="font-size: 14px; line-height: 1.5; margin-bottom: 20px; color: var(--primary-light);">
              Comparez jusqu'à 3 offres d'artisans couvreurs qualifiés basés dans le Vaucluse. Estimation gratuite en 2 minutes.
            </p>
            <a href="/devis/" class="contact-btn" style="display: block; text-align: center; background: var(--secondary); color: var(--primary) !important;">Demander un Devis</a>
          </div>

          <div style="background: white; border: 1.5px solid var(--border-color); border-left: 4px solid var(--secondary); border-radius: var(--radius-sm); padding: 25px; box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 15px;">Dossiers Pratiques</h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px; font-size: 14px; padding: 0;">
              <li><a href="/tarifs/" style="color: var(--text); font-weight: bold;">📊 Grille de Tarifs 2026</a></li>
              <li><a href="/guide-mistral-toiture/" style="color: var(--text); font-weight: bold;">💨 Le Mistral &amp; Votre Toit</a></li>
              <li><a href="/restauration-mas-provencal/" style="color: var(--text); font-weight: bold;">🏡 Restauration Mas</a></li>
              <li><a href="/communes/" style="color: var(--text); font-weight: bold;">🗺️ Annuaire Communes (84)</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style>
  aside a {
    text-decoration: none;
    transition: var(--transition);
  }
  aside a:hover {
    color: var(--accent) !important;
  }
</style>
