---
import config from '../data/config.json';
import '../styles/global.css';
import communes from '../data/communes.json';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
}

const { 
  title = `${config.brandName} | Couvreur RGE & Travaux de Toiture Vaucluse (84) — Devis Gratuit`, 
  description = "Artisans couvreurs qualifiés pour vos travaux de toiture et couverture dans le Vaucluse (84). Rénovation, restauration, démoussage hydrofuge et réparation de fuites.",
  canonicalUrl,
  robots = 'index, follow'
} = Astro.props;

const siteUrl = `https://${config.domain}`;

// Auto-generate canonical URL
let resolvedPathname = Astro.url.pathname;
if (!resolvedPathname.endsWith('/')) {
  resolvedPathname += '/';
}
const resolvedCanonical = canonicalUrl || `${siteUrl}${resolvedPathname}`;

// Top 10 communes for footer
const topFooterCommunes = communes.slice(0, 10);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Favicon & Styles -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <link rel="alternate" hreflang="fr" href={resolvedCanonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={config.brandName} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteUrl}/images/hero-toiture-vaucluse.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/hero-toiture-vaucluse.png`} />

    <!-- Local SEO -->
    <meta name="geo.region" content="FR-84" />
    <meta name="geo.placename" content={config.mainCity} />

    <slot name="head" />
  </head>
  <body>
    <!-- Header -->
    <header>
      <div class="container header-inner">
        <a href="/" class="logo" id="main-logo-link">
          <span>🏚️</span> {config.brandName}
        </a>
        <nav class="header-nav" aria-label="Navigation principale" id="main-nav-bar">
          <a href="/" id="nav-home">Accueil</a>
          <a href="/tarifs/" id="nav-tarifs">🧮 Tarifs 2026</a>
          <a href="/guide-mistral-toiture/" id="nav-mistral">💨 Mistral &amp; Toits</a>
          <a href="/restauration-mas-provencal/" id="nav-mas">🏡 Mas Provençal</a>
          <a href="/guides/" id="nav-guides">📚 Guides</a>
          <a href="/communes/" id="nav-communes">Villes (84)</a>
        </nav>
        <div class="header-actions">
          <a href="/devis/" class="contact-btn" id="header-cta-quote">
            📋 Devis<span class="hide-mobile-text"> Gratuit</span>
          </a>
          <button class="mobile-menu-toggle" id="menu-toggle-btn" aria-label="Ouvrir le menu" aria-expanded="false">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
          </button>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer>
      <div class="container footer-grid">
        <div class="footer-brand">
          <h3>🏚️ {config.brandName}</h3>
          <p style="margin-top: 15px; font-size: 14px; line-height: 1.6; color: #a8a29e;">
            Votre service indépendant d'estimation et de mise en relation de toiture dans le Vaucluse ({config.departmentCode}). 
            Rénovation de toitures en tuiles romanes, pose de tuiles canal traditionnelles dans le Luberon et le Comtat Venaissin, traitement anti-mousse hydrofuge de toiture à Avignon, Carpentras et Orange, 
            et travaux urgents après dégâts de tempête et mistral dévastateur. Obtenez rapidement 3 devis d'artisans locaux qualifiés RGE.
          </p>
        </div>
        
        <div class="footer-links">
          <h3 style="font-size: 16px; text-transform: uppercase; color: white;">Villes Populaires</h3>
          <ul style="margin-top: 15px; list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
            {topFooterCommunes.map((c) => (
              <li style="font-size: 13.5px;">
                <a href={`/travaux-toiture-${c.slug}/`} style="font-weight: 700; color: #d8b4fe;">{c.nom}</a>
                <span style="font-size: 11px; color: #a8a29e; margin-left: 4px;">
                  (<a href={`/restauration-toiture-${c.slug}/`} style="color: #a855f7; text-decoration: none;" title={`Restauration ${c.nom}`}>restauration</a> · <a href={`/artisan-qualifie-${c.slug}/`} style="color: #a855f7; text-decoration: none;" title={`Artisan RGE ${c.nom}`}>artisan</a>)
                </span>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="footer-links">
          <h3 style="font-size: 16px; text-transform: uppercase; color: white;">Dossiers &amp; Guides</h3>
          <ul style="margin-top: 15px; list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
            <li><a href="/tarifs/">Grille de Tarifs Toiture 2026</a></li>
            <li><a href="/guide-mistral-toiture/">Le Mistral &amp; Votre Toiture</a></li>
            <li><a href="/restauration-mas-provencal/">Restauration Mas Provençal</a></li>
            <li><a href="/devis/">Demander un Devis Gratuit</a></li>
            <li><a href="/communes/">Index de toutes les Communes</a></li>
          </ul>
          
          <h3 style="font-size: 16px; text-transform: uppercase; color: white; margin-top: 25px;">Articles Récents</h3>
          <ul style="margin-top: 10px; list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
            <li><a href="/guides/prix-toiture-vaucluse-2026/">Budget Toiture Vaucluse 2026</a></li>
            <li><a href="/guides/tuiles-canal-patinees/">Guide Tuiles Canal Patinées</a></li>
            <li><a href="/guides/genoises-provencales/">Restauration des Génoises</a></li>
            <li><a href="/guides/toiture-village-perche-luberon/">Accès Spéciaux Luberon</a></li>
          </ul>
        </div>
      </div>
      
      <div class="container footer-bottom">
        <p style="color: #78716c;">&copy; {new Date().getFullYear()} {config.brandName}. Tous droits réservés.</p>
        <p style="margin-top: 10px;">
          <a href="/mentions-legales/" id="footer-link-legal" style="color: #78716c; font-size: 12px; margin-right: 15px;">Mentions Légales</a>
          <a href="/politique-confidentialite/" id="footer-link-privacy" style="color: #78716c; font-size: 12px;">Politique de Confidentialité</a>
        </p>
      </div>
    </footer>

    <!-- Exit Intent Popup -->
    <ExitIntentPopup />

    <script>
      // Smooth scroll to devis form if present on same page
      document.querySelectorAll('a[href="/devis/"], a[href="#devis"], .contact-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const targetForm = document.getElementById('devis');
          if (targetForm) {
            e.preventDefault();
            targetForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
            targetForm.classList.add('pulse-form');
            setTimeout(() => {
              targetForm.classList.remove('pulse-form');
            }, 3000);

            const firstBox = targetForm.querySelector('.option-box') as HTMLElement;
            if (firstBox) {
              firstBox.focus();
              firstBox.style.outline = '3px solid var(--secondary)';
              setTimeout(() => {
                if (firstBox) firstBox.style.outline = '';
              }, 3000);
            }
          }
        });
      });

      // Mobile menu toggle
      const menuToggleBtn = document.getElementById('menu-toggle-btn');
      const headerNav = document.getElementById('main-nav-bar');
      if (menuToggleBtn && headerNav) {
        menuToggleBtn.addEventListener('click', () => {
          const isActive = menuToggleBtn.classList.toggle('active');
          headerNav.classList.toggle('active');
          menuToggleBtn.setAttribute('aria-expanded', isActive.toString());
        });
      }
    </script>
  </body>
</html>
